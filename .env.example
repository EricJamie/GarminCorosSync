# Garmin ⇄ Coros Sync - Environment Configuration
# Copy this file to .env and fill in your credentials

# ─── Coros Account (required) ─────────────────────────────────────────────────
COROS_EMAIL=your_coros_email@example.com
COROS_PASSWORD=your_coros_password

# ─── Garmin Account ────────────────────────────────────────────────────────────
#
# Option A: Token as string (RECOMMENDED for GitHub Actions / 2FA users)
#   - Get content from ~/.garminconnect/{user_id}/garmin_tokens.json
#   - Paste the entire JSON as the value
# GARMIN_TOKEN_DATA={"access_token": "...", ...}

# Option B: Email + password (ONLY for non-2FA accounts)
# GARMIN_EMAIL=your_garmin_email@example.com
# GARMIN_PASSWORD=your_garmin_password

# ─── Sync Settings ───────────────────────────────────────────────────────────
GARMIN_NEWEST_NUM=1000
