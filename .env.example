# Garmin <-> Coros Sync - Environment Configuration

# Coros
COROS_EMAIL=your_coros_email@example.com
COROS_PASSWORD=your_coros_password

# Garmin Intl
# Option A: token JSON string (the full contents of garmin_tokens.json)
# GARMIN_TOKEN_DATA={"di_token":"...","di_refresh_token":"...","di_client_id":"..."}

# Option B: email + password (used only to bootstrap or refresh token JSON)
# GARMIN_EMAIL=your_garmin_email@example.com
# GARMIN_PASSWORD=your_garmin_password

# Sync Settings
GARMIN_NEWEST_NUM=1000
